{
  "name": "@jamaalbuilds/ai-toolkit",
  "version": "0.1.0",
  "description": "TypeScript SDK for building AI-powered full-stack applications. LLM client, MCP tools, caching, auth, observability, and more.",
  "author": "Danilo Batson <djbatson19@gmail.com>",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "import": "./dist/config/index.js"
    },
    "./errors": {
      "types": "./dist/errors/index.d.ts",
      "import": "./dist/errors/index.js"
    },
    "./ai": {
      "types": "./dist/ai/index.d.ts",
      "import": "./dist/ai/index.js"
    },
    "./mcp": {
      "types": "./dist/mcp/index.d.ts",
      "import": "./dist/mcp/index.js"
    },
    "./storage": {
      "types": "./dist/storage/index.d.ts",
      "import": "./dist/storage/index.js"
    },
    "./database": {
      "types": "./dist/database/index.d.ts",
      "import": "./dist/database/index.js"
    },
    "./auth": {
      "types": "./dist/auth/index.d.ts",
      "import": "./dist/auth/index.js"
    },
    "./monitor": {
      "types": "./dist/monitor/index.d.ts",
      "import": "./dist/monitor/index.js"
    },
    "./observability": {
      "types": "./dist/observability/index.d.ts",
      "import": "./dist/observability/index.js"
    },
    "./security": {
      "types": "./dist/security/index.d.ts",
      "import": "./dist/security/index.js"
    },
    "./data": {
      "types": "./dist/data/index.d.ts",
      "import": "./dist/data/index.js"
    },
    "./cache": {
      "types": "./dist/cache/index.d.ts",
      "import": "./dist/cache/index.js"
    },
    "./api": {
      "types": "./dist/api/index.d.ts",
      "import": "./dist/api/index.js"
    },
    "./health": {
      "types": "./dist/health/index.d.ts",
      "import": "./dist/health/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "biome check src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/node": "22.19.11",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  },
  "peerDependencies": {
    "@ai-sdk/groq": "3.0.31",
    "@anthropic-ai/sdk": ">=0.30.0",
    "@modelcontextprotocol/sdk": ">=1.0.0",
    "drizzle-orm": "0.45.2",
    "@neondatabase/serverless": ">=0.9.0",
    "postgres": ">=3.4.0",
    "@openrouter/ai-sdk-provider": "2.3.3",
    "@vercel/blob": ">=0.20.0",
    "ai": "6.0.141",
    "ioredis": ">=5.0.0",
    "langfuse": "3.38.6",
    "openai": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "@ai-sdk/groq": { "optional": true },
    "@anthropic-ai/sdk": { "optional": true },
    "@modelcontextprotocol/sdk": { "optional": true },
    "drizzle-orm": { "optional": true },
    "@neondatabase/serverless": { "optional": true },
    "postgres": { "optional": true },
    "@openrouter/ai-sdk-provider": { "optional": true },
    "@vercel/blob": { "optional": true },
    "ai": { "optional": true },
    "ioredis": { "optional": true },
    "langfuse": { "optional": true },
    "openai": { "optional": true }
  },
  "keywords": [
    "ai", "toolkit", "llm", "mcp", "model-context-protocol",
    "rag", "agents", "embeddings", "typescript", "sdk"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/danilobatson/ai-toolkit",
    "directory": "packages/toolkit"
  }
}
